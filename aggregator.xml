<?xml version="1.0" encoding="UTF-8"?>
<!--
  Full-stack aggregator — NOT a parent pom, not published, not a dependency.
  Used only to drive a local or CI reactor build across all ecosystem repos.

  Usage:
    mvn install -f aggregator.xml               # build foundation + integration
    mvn install -f aggregator.xml -DskipTests   # skip tests
    mvn install -f aggregator.xml -T 1C         # parallel (safe for independent modules)
    mvn install -f aggregator.xml -Plangchain4j # include quarkus-langchain4j (slow)

  All repos must be cloned as siblings of this parent under ~/claude/casehub/.
  Maven's reactor resolves build order automatically from declared dependencies.
  Application repos (devtown, aml, clinical) are excluded by default.
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>io.casehub</groupId>
  <artifactId>casehub-aggregator</artifactId>
  <version>0.2-SNAPSHOT</version>
  <packaging>pom</packaging>

  <name>CaseHub :: Full Stack Aggregator</name>
  <description>
    Aggregator-only POM. Lists all ecosystem repos as Maven reactor modules so the
    full stack can be built with a single mvn command. Each module retains its own
    parent pom — this aggregator adds no inheritance, only reactor coordination.
  </description>

  <modules>
    <!-- All repos are siblings of this parent under ~/claude/casehub/ -->
    <module>../platform</module>
    <module>../ledger</module>
    <module>../eidos</module>
    <module>../connectors</module>
    <module>../work</module>
    <module>../qhorus</module>
    <!-- pages: yarn-only, not a Maven module -->
    <module>../engine</module>
    <module>../workers</module>
    <module>../claudony</module>
  </modules>

  <profiles>
    <profile>
      <!-- Activate with -Plangchain4j — slow, only when that fork has changed -->
      <id>langchain4j</id>
      <modules>
        <module>../../quarkus-langchain4j</module>
      </modules>
    </profile>
    <profile>
      <!-- Activate with -Papps — include all non-core repos -->
      <id>apps</id>
      <modules>
        <module>../iot</module>
        <module>../neural-text</module>
        <module>../desiredstate</module>
        <module>../ras</module>
        <module>../ops</module>
        <module>../openclaw</module>
        <module>../devtown</module>
        <module>../aml</module>
        <module>../clinical</module>
        <module>../life</module>
        <module>../drafthouse/server</module>
      </modules>
    </profile>
  </profiles>

</project>
